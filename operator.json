{
  "name": "asinh",
  "description": "Computes the inverse hyperpolic sine (arcsinh, arsinh, or argsinh) of your data.",
  "tags": [
    "preprocessing",
    "transformation"
  ],
  "authors": [
    "tercen"
  ],
  "urls": [
    "https://github.com/tercen/asinh_operator"
  ],
  "properties": [
    {
      "kind": "EnumeratedProperty",
      "name": "method",
      "defaultValue": "fixed",
      "values": ["fixed", "manual", "auto"],
      "description": "Method: 'fixed' uses global scale, 'manual' reads per-channel scales from row factor, 'auto' automatically estimates optimal cofactors per channel"
    },
    {
      "kind": "StringProperty",
      "name": "scale",
      "defaultValue": "5",
      "description": "The scaling factor to use before the transformation (only used when method is 'fixed')"
    },
    {
      "kind": "StringProperty",
      "name": "signifLevel",
      "defaultValue": "0.05",
      "description": "Statistical significance threshold for peak detection (only used when method is 'auto'). Lower values are stricter, detecting fewer peaks. Range: 0.01-0.10"
    },
    {
      "kind": "StringProperty",
      "name": "bwCorr",
      "defaultValue": "1.0",
      "description": "Bandwidth correction factor for peak detection (only used when method is 'auto'). Higher values apply more smoothing, detecting fewer peaks. Use 1.1 to match flowVS more closely on borderline cases. Range: 0.8-1.5"
    }
  ],
  "operatorSpec": {
    "kind": "OperatorSpec",
    "ontologyUri": "https://tercen.com/_ontology/tercen",
    "ontologyVersion": "0.0.1",
    "inputSpecs": [
      {
        "kind": "CrosstabSpec",
        "metaFactors": [
          {
            "kind": "MetaFactor",
            "name": "Row",
            "type": "",
            "description": "Optional row factor (second factor can provide per-channel scale values)",
            "ontologyMapping": "variable",
            "crosstabMapping": "row",
            "cardinality": "0..n",
            "factors": []
          },
          {
            "kind": "MetaFactor",
            "name": "Column",
            "type": "",
            "description": "Optional column factor",
            "ontologyMapping": "observation",
            "crosstabMapping": "column",
            "cardinality": "0..n",
            "factors": []
          }
        ],
        "axis": [
          {
            "kind": "AxisSpec",
            "metaFactors": [
              {
                "kind": "MetaFactor",
                "name": "Measurement",
                "type": "double",
                "description": "Values to transform",
                "ontologyMapping": "measurement",
                "crosstabMapping": "y",
                "cardinality": "1",
                "factors": []
              }
            ]
          }
        ]
      }
    ],
    "outputSpecsV2": [
      {
        "kind": "OperatorJoinSpec",
        "joinOperators": [
          {
            "kind": "JoinOperator",
            "joinType": "left",
            "leftPair": {
              "kind": "ColumnPair",
              "lColumns": [
                "Row",
                "Column"
              ],
              "rColumns": [
                "Row",
                "Column"
              ]
            },
            "rightRelation": {
              "kind": "TableRelation",
              "attributes": [
                {
                  "kind": "Attribute",
                  "name": "asinh",
                  "type": "double"
                }
              ]
            }
          }
        ]
      }
    ]
  }
}
